API_ADDR=:8080
ALLOW_INSECURE_DEV=false
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
JWT_TTL=72h
COMMISSION_RATE=0.10

# Set to true only for non-production testing if you don't have SMS wired yet.
OTP_DEV_MODE=true
OTP_TTL=5m
AUTH_MAX_FAILS=5
AUTH_LOCK_WINDOW=15m
OTP_MAX_FAILS=5
OTP_LOCK_WINDOW=15m

# Twilio (optional when OTP_DEV_MODE=true)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Uploads
UPLOAD_SIGNING_SECRET=CHANGE_THIS_TOO
UPLOADS_DIR=/app/data/uploads
UPLOAD_TOKEN_TTL=15m

# Payments
PAYMENT_PROVIDER=noop
# PAYMENT_PROVIDER=stripe_connect
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_REFRESH_URL=
STRIPE_CONNECT_RETURN_URL=
STRIPE_DEFAULT_PAYMENT_METHOD=
